# ── Base defaults (all environments) ──────────────────────────────────────────
# Never put secrets here — this file IS committed to source control.
# Secrets go in .env.local (gitignored).

PORT=4000
NODE_ENV=development
APP_ENV=development

# Comma-separated list of CORS-allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:4000,https://studio.apollographql.com

# Java REST API — leave blank until the real backend is available.
# Resolvers fall back to mock data when this is unset.
# JAVA_API_URL=
# JAVA_API_KEY=
