# ── Local overrides template ───────────────────────────────────────────────────
# Copy this file to .env.local (gitignored) and fill in your personal values.
# .env.local is loaded last and overrides everything else.
#
# Usage:
#   cp .env.local.example .env.local
#   # then edit .env.local

# PORT=4000

# Point at a local Java API instance
# JAVA_API_URL=http://localhost:8080
# JAVA_API_KEY=your-dev-key-here
